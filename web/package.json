{
  "name": "ders-dagitim-web",
  "private": true,
  "type": "module",
  "description": "Ders dağıtım motorunun tarayıcı-içi (veri-yerel, Karar 20) TypeScript gerçeklemesi. Python (deney/) referans gerçeklemedir; eşdeğerlik altın testlerle korunur (Karar 22).",
  "scripts": {
    "dev": "vite",
