    "@vitejs/plugin-react": "^5.2.0",
    "typescript": "^5.6.0",
    "vite": "^7.3.6",
    "vitest": "^3.0.0",
    "wrangler": "^4.114.0"
  },
  "dependencies": {
    "or-tools-wasm": "0.9.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
